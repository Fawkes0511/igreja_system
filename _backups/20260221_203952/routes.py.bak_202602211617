@main_bp.route('/evento/<int:evento_id>/presenca', methods=['GET', 'POST'])
@login_required
def gestao_presenca(evento_id):
    evento = Evento.query.get_or_404(evento_id)

    if request.method == 'POST':
        data = request.get_json() or {}
        for item in data.get('presencas', []):
            presenca = Presenca.query.filter_by(evento_id=evento_id, membro_id=item['membro_id']).first()
            if not presenca:
                presenca = Presenca(evento_id=evento_id, membro_id=item['membro_id'])
                db.session.add(presenca)

            presenca.presente = item.get('presente', False)

            if item.get('presente'):
                if not presenca.checkin_time:
                    presenca.checkin_time = datetime.utcnow()
            else:
                presenca.checkin_time = None

            presenca.observacoes = item.get('observacoes', '')

        db.session.commit()
        return jsonify({'success': True})

    membros = Membro.query.filter_by(ativo=True).order_by(Membro.nome).all()
    presencas_existentes = Presenca.query.filter_by(evento_id=evento_id).all()
    presenca_dict = {p.membro_id: p for p in presencas_existentes}
    return render_template('main/presenca_evento.html', evento=evento, membros=membros, presencas=presenca_dict)

@main_bp.route('/evento/<int:evento_id>/gerar_lista', methods=['GET', 'POST'])
@login_required
def gerar_lista_presenca(evento_id):
    evento = Evento.query.get_or_404(evento_id)

    if request.method == 'POST':
        membros_ids = request.form.getlist('membros[]')
        if not getattr(evento, 'codigo_checkin', None):
            import secrets
            evento.codigo_checkin = f"EV{evento_id}_{secrets.token_hex(8)}"
            db.session.commit()

        for membro_id in membros_ids:
            if not Presenca.query.filter_by(evento_id=evento_id, membro_id=membro_id).first():
                db.session.add(Presenca(evento_id=evento_id, membro_id=membro_id))

        db.session.commit()
        return redirect(url_for('main.gestao_presenca', evento_id=evento_id))

    membros = Membro.query.filter_by(ativo=True).order_by(Membro.nome).all()
    return render_template('main/gerar_lista_modal.html', evento=evento, membros=membros)

@main_bp.route('/checkin/qr/<codigo>', methods=['GET', 'POST'])
def checkin_qr(codigo):
    evento = Evento.query.filter_by(codigo_checkin=codigo).first_or_404()

    if request.method == 'POST':
        data = request.get_json() or {}
        membro_id = data.get('membro_id')
        if not membro_id:
            return jsonify({'error': 'ID inválido'}), 400

        presenca = Presenca.query.filter_by(evento_id=evento.id, membro_id=membro_id).first()
        if not presenca:
            presenca = Presenca(evento_id=evento.id, membro_id=membro_id)
            db.session.add(presenca)

        presenca.presente = True
        presenca.checkin_time = datetime.utcnow()
        db.session.commit()
        return jsonify({'success': True, 'message': 'Check-in OK!'})

    membros = Membro.query.filter_by(ativo=True).order_by(Membro.nome).all()
    return render_template('main/checkin_qr.html', evento=evento, membros=membros, codigo=codigo)
