ALLOWED_EXTENSIONS = {'png', 'jpg', 'jpeg', 'gif'}

def allowed_file(filename: str) -> bool:
    return '.' in filename and filename.rsplit('.', 1)[1].lower() in ALLOWED_EXTENSIONS

def _get_attr(obj, name: str, default=None):
    return getattr(obj, name, default)

def _set_if_exists(obj, name: str, value):
    if hasattr(obj, name):
        setattr(obj, name, value)

@main_bp.route('/dashboard', methods=['GET', 'POST'])
@login_required
def dashboard():
    if request.method == 'POST':
        try:
            membro_id = request.form.get('membro_id')
            data_nasc_str = request.form.get('data_nascimento')
            data_batismo_str = request.form.get('data_batismo')

            data_nasc = datetime.strptime(data_nasc_str, '%Y-%m-%d').date() if data_nasc_str else None
            data_batismo = datetime.strptime(data_batismo_str, '%Y-%m-%d').date() if data_batismo_str else None

            if membro_id:
                membro = Membro.query.get_or_404(membro_id)
                msg = 'Membro atualizado com sucesso!'
            else:
                membro = Membro()
                db.session.add(membro)
                msg = 'Membro cadastrado com sucesso!'

            membro.nome = request.form.get('nome')
            membro.data_nascimento = data_nasc
            membro.tipo = request.form.get('tipo_membro')
            membro.observacoes = request.form.get('observacoes')

            _set_if_exists(membro, 'data_batismo', data_batismo)
            _set_if_exists(membro, 'responsaveis', request.form.get('responsaveis'))
            _set_if_exists(membro, 'alergias', request.form.get('info_medica'))

            cong_ids = request.form.getlist('congregacoes[]')
            if cong_ids:
                membro.congregações = Congregacao.query.filter(Congregacao.id.in_(cong_ids)).all()

            if 'foto' in request.files:
                file = request.files['foto']
                if file and file.filename != '' and allowed_file(file.filename):
                    filename = secure_filename(f"membro_{datetime.now().timestamp()}_{file.filename}")
                    upload_folder = os.path.join(os.path.dirname(current_app.root_path), 'app/static/img/membros')
                    os.makedirs(upload_folder, exist_ok=True)
                    file.save(os.path.join(upload_folder, filename))
                    _set_if_exists(membro, 'foto_path', f'img/membros/{filename}')

            db.session.flush()

            if not membro_id:
                min_id = request.form.get('ministerio_id')
                func_id = request.form.get('funcao_id')
                if min_id and func_id:
                    db.session.add(MembroMinisterio(membro_id=membro.id, ministerio_id=min_id, funcao_id=func_id))

            db.session.commit()
            flash(msg, 'success')

        except Exception as e:
            db.session.rollback()
            flash(f'Erro ao salvar: {str(e)}', 'danger')
            current_app.logger.exception(e)

        return redirect(url_for('main.dashboard'))

    membros = Membro.query.order_by(Membro.nome).all()

    membros_json = []
    for m in membros:
        data_bat = _get_attr(m, 'data_batismo', None)
        membros_json.append({
            'id': m.id,
            'nome': m.nome,
            'data_nascimento': m.data_nascimento.strftime('%Y-%m-%d') if m.data_nascimento else '',
            'data_batismo': data_bat.strftime('%Y-%m-%d') if data_bat else '',
            'tipo': m.tipo,
            'responsaveis': _get_attr(m, 'responsaveis', ''),
            'info_medica': _get_attr(m, 'alergias', ''),
            'observacoes': _get_attr(m, 'observacoes', ''),
            'congregações': [{'id': c.id} for c in getattr(m, 'congregações', [])],
        })

    return render_template(
        'main/dashboard.html',
        congregacoes=Congregacao.query.all(),
        ministerios=Ministerio.query.all(),
        funcoes=Funcao.query.all(),
        membros=membros,
        membros_json=membros_json
    )

@main_bp.route('/eventos', methods=['GET', 'POST'])
@login_required
def eventos():
    if request.method == 'POST':
        tipo = request.form.get('tipo_acao')
        id_edicao = request.form.get('id_edicao')

        if tipo == 'novo_evento':
            data_str = request.form.get('data_evento')
            data_dt = datetime.strptime(data_str, '%Y-%m-%dT%H:%M')
            novo = Evento(
                titulo=request.form.get('titulo'),
                descricao=request.form.get('descricao'),
                data_evento=data_dt,
                congregacao_id=request.form.get('congregacao_id'),
                permite_inscricao='permite_inscricao' in request.form
            )
            db.session.add(novo)

        elif tipo == 'editar_evento':
            evento = Evento.query.get_or_404(id_edicao)
            evento.titulo = request.form.get('titulo')
            evento.descricao = request.form.get('descricao')
            evento.data_evento = datetime.strptime(request.form.get('data_evento'), '%Y-%m-%dT%H:%M')
            evento.congregacao_id = request.form.get('congregacao_id')
            evento.permite_inscricao = 'permite_inscricao' in request.form

        elif tipo == 'nova_agenda':
            horario = datetime.strptime(request.form.get('horario'), '%H:%M').time()
            nova = Agenda(
                titulo=request.form.get('titulo'),
                dia_semana=int(request.form.get('dia_semana')),
                horario=horario,
                tipo=request.form.get('tipo'),
                congregacao_id=request.form.get('congregacao_id')
            )
            db.session.add(nova)

        elif tipo == 'editar_agenda':
            agenda = Agenda.query.get_or_404(id_edicao)
            agenda.titulo = request.form.get('titulo')
            agenda.dia_semana = int(request.form.get('dia_semana'))
            agenda.horario = datetime.strptime(request.form.get('horario'), '%H:%M').time()
            agenda.tipo = request.form.get('tipo')
            agenda.congregacao_id = request.form.get('congregacao_id')

        db.session.commit()
        return redirect(url_for('main.eventos'))

    return render_template(
        'main/eventos.html',
        eventos=Evento.query.order_by(Evento.data_evento).all(),
        agenda=Agenda.query.order_by(Agenda.dia_semana, Agenda.horario).all(),
        congregacoes=Congregacao.query.all()
    )

