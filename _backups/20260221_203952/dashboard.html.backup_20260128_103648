{% extends "base.html" %}
{% block page_title %}Cadastro de Membros{% endblock %}
{% block content %}
<div style="margin-bottom: 30px;">
    <h2 style="font-family: 'Merriweather', serif; color: var(--azul-marinho); margin-bottom: 15px;">Cadastrar Novo Membro</h2>
</div>

<!-- Formulário de Cadastro -->
<div class="card" style="margin-bottom: 30px;">
    <form method="POST" id="membro-form">
        <input type="hidden" name="membro_id" id="membro_id">

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 20px;">
            <div>
                <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--azul-marinho);">Nome Completo *</label>
                <input type="text" name="nome" id="nome" required style="width: 100%; padding: 12px; border: 1px solid var(--cinza-borda); border-radius: 6px; font-family: 'Lato', sans-serif;">
            </div>
            <div>
                <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--azul-marinho);">Data de Nascimento *</label>
                <input type="date" name="data_nascimento" id="data_nascimento" required style="width: 100%; padding: 12px; border: 1px solid var(--cinza-borda); border-radius: 6px; font-family: 'Lato', sans-serif;">
            </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 20px;">
            <div>
                <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--azul-marinho);">Tipo de Membro</label>
                <select name="tipo_membro" id="tipo_membro" onchange="toggleCamposCrianca()" style="width: 100%; padding: 12px; border: 1px solid var(--cinza-borda); border-radius: 6px; font-family: 'Lato', sans-serif;">
                    <option value="Adulto">Adulto</option>
                    <option value="Criança">Criança</option>
                    <option value="Visitante">Visitante</option>
                </select>
            </div>
            <div>
                <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--azul-marinho);">Data de Batismo/Consagração</label>
                <input type="date" name="data_batismo" id="data_batismo" style="width: 100%; padding: 12px; border: 1px solid var(--cinza-borda); border-radius: 6px; font-family: 'Lato', sans-serif;">
            </div>
            <div>
                <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--azul-marinho);">Ministério Inicial</label>
                <select name="ministerio_id" style="width: 100%; padding: 12px; border: 1px solid var(--cinza-borda); border-radius: 6px; font-family: 'Lato', sans-serif;">
                    <option value="">Nenhum</option>
                    {% for min in ministerios %}
                    <option value="{{ min.id }}">{{ min.nome }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>

        <!-- Campos Específicos para Criança -->
        <div id="campos-crianca" style="display: none; background: rgba(39, 174, 96, 0.05); border: 1px solid var(--verde-folha); border-radius: 8px; padding: 20px; margin-bottom: 20px;">
            <h4 style="color: var(--verde-folha); margin-bottom: 15px; font-size: 15px;"><i class="fas fa-child"></i> Informações da Criança</h4>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
                <div>
                    <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--verde-folha);">Responsáveis (Pai/Mãe)</label>
                    <input type="text" name="responsaveis" id="responsaveis" style="width: 100%; padding: 12px; border: 1px solid var(--cinza-borda); border-radius: 6px; font-family: 'Lato', sans-serif;">
                </div>
                <div>
                    <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--verde-folha);">Informações Médicas / Alergias</label>
                    <input type="text" name="info_medica" id="info_medica" style="width: 100%; padding: 12px; border: 1px solid var(--cinza-borda); border-radius: 6px; font-family: 'Lato', sans-serif;">
                </div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 20px;">
            <div>
                <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--azul-marinho);">Função Inicial</label>
                <select name="funcao_id" style="width: 100%; padding: 12px; border: 1px solid var(--cinza-borda); border-radius: 6px; font-family: 'Lato', sans-serif;">
                    <option value="">Nenhuma</option>
                    {% for func in funcoes %}
                    <option value="{{ func.id }}">{{ func.nome }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--azul-marinho);">Congregações</label>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin-top: 5px;">
                    {% for cong in congregacoes %}
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 13px;">
                        <input type="checkbox" name="congregacoes[]" value="{{ cong.id }}" id="cong_{{ cong.id }}" style="width: 16px; height: 16px;">
                        <span>{{ cong.nome }}</span>
                    </label>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div style="margin-bottom: 25px;">
            <label style="display: block; font-weight: 700; font-size: 13px; margin-bottom: 8px; color: var(--azul-marinho);">Observações Adicionais</label>
            <textarea name="observacoes" id="observacoes" rows="3" style="width: 100%; padding: 12px; border: 1px solid var(--cinza-borda); border-radius: 6px; font-family: 'Lato', sans-serif;"></textarea>
        </div>

        <div style="display: flex; gap: 15px; align-items: center;">
            <button type="submit" class="btn-primary" style="padding: 12px 30px;">
                <i class="fas fa-save"></i> Salvar Membro
            </button>
            <button type="button" onclick="resetForm()" style="background: none; border: none; color: var(--cinza-texto); cursor: pointer; font-weight: 700; padding: 12px 20px;">
                <i class="fas fa-eraser"></i> Limpar
            </button>
        </div>
    </form>
</div>

<!-- Lista de Membros -->
<div class="card">
    <h3 style="color: var(--azul-marinho); margin-bottom: 20px; border-bottom: 1px solid var(--cinza-borda); padding-bottom: 10px;">Membros Cadastrados</h3>
    
    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: var(--cinza-fundo);">
                    <th style="padding: 12px 15px; text-align: left; font-weight: 700; font-size: 13px; color: var(--azul-marinho); border-bottom: 2px solid var(--cinza-borda);">Nome</th>
                    <th style="padding: 12px 15px; text-align: left; font-weight: 700; font-size: 13px; color: var(--azul-marinho); border-bottom: 2px solid var(--cinza-borda);">Tipo</th>
                    <th style="padding: 12px 15px; text-align: left; font-weight: 700; font-size: 13px; color: var(--azul-marinho); border-bottom: 2px solid var(--cinza-borda);">Congregações</th>
                    <th style="padding: 12px 15px; text-align: left; font-weight: 700; font-size: 13px; color: var(--azul-marinho); border-bottom: 2px solid var(--cinza-borda);">Ministério / Função</th>
                    <th style="padding: 12px 15px; text-align: left; font-weight: 700; font-size: 13px; color: var(--azul-marinho); border-bottom: 2px solid var(--cinza-borda);">Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for m in membros %}
                <tr style="border-bottom: 1px solid var(--cinza-borda);">
                    <td style="padding: 15px;">
                        <div style="font-weight: 700; color: var(--preto-texto);">{{ m.nome }}</div>
                        {% if m.responsaveis %}
                        <div style="font-size: 12px; color: var(--cinza-texto); margin-top: 5px;">
                            <i class="fas fa-user-friends"></i> {{ m.responsaveis }}
                        </div>
                        {% endif %}
                    </td>
                    <td style="padding: 15px;">
                        {% if m.tipo == 'Criança' %}
                        <span style="background: rgba(52, 152, 219, 0.1); color: #3498db; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; border: 1px solid rgba(52, 152, 219, 0.3);">
                            <i class="fas fa-child"></i> {{ m.tipo }}
                        </span>
                        {% elif m.tipo == 'Visitante' %}
                        <span style="background: rgba(241, 196, 15, 0.1); color: var(--amarelo-dourado); padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; border: 1px solid rgba(241, 196, 15, 0.3);">
                            <i class="fas fa-user-clock"></i> {{ m.tipo }}
                        </span>
                        {% else %}
                        <span style="background: rgba(39, 174, 96, 0.1); color: var(--verde-folha); padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; border: 1px solid rgba(39, 174, 96, 0.3);">
                            <i class="fas fa-user-check"></i> {{ m.tipo }}
                        </span>
                        {% endif %}
                    </td>
                    <td style="padding: 15px;">
                        <div style="display: flex; flex-wrap: wrap; gap: 5px;">
                            {% for c in m.congregações %}
                            <span style="background: var(--cinza-fundo); border: 1px solid var(--cinza-borda); border-radius: 4px; padding: 3px 8px; font-size: 11px; color: var(--cinza-texto);">
                                {{ c.nome }}
                            </span>
                            {% endfor %}
                        </div>
                    </td>
                    <td style="padding: 15px;">
                        {% for vinculo in m.vinculos_ministerio %}
                        <div style="margin-bottom: 5px;">
                            <span style="color: var(--azul-marinho); font-weight: 700; font-size: 13px;">{{ vinculo.ministerio.nome }}</span>
                            <span style="color: var(--cinza-texto); margin: 0 5px;">|</span>
                            <span style="color: var(--laranja-fogo); font-size: 12px;">{{ vinculo.funcao.nome }}</span>
                        </div>
                        {% endfor %}
                    </td>
                    <td style="padding: 15px;">
                        <div style="display: flex; gap: 10px;">
                            <button onclick="prepararEdicao({{ m.id }})" style="background: none; border: 1px solid var(--azul-marinho); color: var(--azul-marinho); padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px; display: flex; align-items: center; gap: 5px;">
                                <i class="fas fa-edit"></i> Editar
                            </button>
                            <a href="{{ url_for('main.deletar_membro', id=m.id) }}" onclick="return confirm('Excluir membro?')" style="background: none; border: 1px solid var(--laranja-fogo); color: var(--laranja-fogo); padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px; text-decoration: none; display: flex; align-items: center; gap: 5px;">
                                <i class="fas fa-trash"></i> Excluir
                            </a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
const membrosData = {{ membros_json | tojson }};

function toggleCamposCrianca() {
    const tipo = document.getElementById('tipo_membro').value;
    const divCrianca = document.getElementById('campos-crianca');
    if (divCrianca) {
        divCrianca.style.display = (tipo === 'Criança') ? 'block' : 'none';
    }
}

function prepararEdicao(id) {
    const m = membrosData.find(item => item.id === id);
    if (!m) return;

    document.getElementById('membro_id').value = m.id;
    document.getElementById('nome').value = m.nome;
    document.getElementById('data_nascimento').value = m.data_nascimento;
    document.getElementById('data_batismo').value = m.data_batismo || '';
    document.getElementById('tipo_membro').value = m.tipo;
    document.getElementById('responsaveis').value = m.responsaveis || '';
    document.getElementById('info_medica').value = m.info_medica || '';
    document.getElementById('observacoes').value = m.observacoes || '';

    // Marcar checkboxes das congregações
    document.querySelectorAll('input[name="congregacoes[]"]').forEach(cb => {
        cb.checked = false;
    });
    
    if (m.congregações) {
        m.congregações.forEach(c => {
            const cb = document.getElementById('cong_' + c.id);
            if(cb) cb.checked = true;
        });
    }

    toggleCamposCrianca();
    
    // Rolar para o topo do formulário
    window.scrollTo({ top: 0, behavior: 'smooth' });
    
    // Atualizar título do formulário
    document.querySelector('h2').innerHTML = `Editar Membro: <span style="color: var(--verde-folha);">${m.nome}</span>`;
}

function resetForm() {
    document.getElementById('membro-form').reset();
    document.getElementById('membro_id').value = '';
    document.querySelector('h2').innerText = 'Cadastrar Novo Membro';
    toggleCamposCrianca();
}

// Inicializar ao carregar a página
document.addEventListener('DOMContentLoaded', function() {
    toggleCamposCrianca();
});
</script>
{% endblock %}
