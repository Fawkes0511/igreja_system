{% extends "base.html" %}
{% block page_title %}Agenda e Gestão de Eventos{% endblock %}

{% block content %}
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js'></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .calendar-container { background: #fff; border-radius: 16px; padding: 25px; border: 1px solid #e2e8f0; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .fc { font-family: 'Inter', sans-serif; --fc-border-color: #f1f5f9; --fc-today-bg-color: rgba(46, 134, 193, 0.05); height: 750px; }
    .fc-theme-standard th { border: none; }
    .fc-col-header-cell { background: var(--azul-marinho); padding: 12px 0; border: none !important; }
    .fc-col-header-cell-cushion { color: #fff !important; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; font-weight: 700; text-decoration: none; }
    .fc-daygrid-day { transition: background 0.2s; }
    .fc-daygrid-day:hover { background: #f8fafc; }
    .fc-daygrid-day-number { color: #64748b; font-weight: 800; padding: 8px 12px !important; text-decoration: none; }
    .fc-day-other { visibility: hidden; }
    .fc-event { cursor: pointer; border: none !important; border-radius: 6px !important; padding: 4px 8px !important; margin: 2px 4px !important; font-size: 0.8rem !important; box-shadow: 0 2px 5px rgba(0,0,0,0.08); transition: transform 0.2s; }
    .fc-event:hover { transform: translateY(-1px); box-shadow: 0 4px 8px rgba(0,0,0,0.12); }
    .fc-event-time { font-weight: 800; margin-right: 6px; opacity: 0.85; }
    .fc-event-title { font-weight: 600; }
    .fc-daygrid-event-harness { margin-bottom: 4px; }
    .fc .fc-toolbar-title { font-weight: 800; color: var(--azul-marinho); text-transform: capitalize; display: inline-block; vertical-align: middle; font-size: 1.5rem; }

    .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.6); z-index: 2000; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
    .modal-content { background: #fff; border-radius: 20px; width: 95%; max-width: 650px; max-height: 90vh; overflow-y: auto; padding: 0; position: relative; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2); }

    .modal-tabs { display: flex; border-bottom: 1px solid #e2e8f0; background: #f8fafc; border-radius: 20px 20px 0 0; }
    .tab-btn { flex: 1; padding: 18px 5px; border: none; background: none; font-weight: 800; font-size: 0.85rem; color: #94a3b8; cursor: pointer; transition: 0.2s; text-transform: uppercase; letter-spacing: 0.5px; }
    .tab-btn.active { color: var(--azul-marinho); border-bottom: 3px solid var(--azul-marinho); background: #fff; }

    .member-item { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; border-bottom: 1px solid #f1f5f9; transition: background 0.2s; }
    .member-item:hover { background: #f8fafc; }
    .member-info { display: flex; align-items: center; gap: 12px; }
    .member-img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid #e2e8f0; background: #f1f5f9; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 16px; }

    .toggle-group { display: flex; background: #f1f5f9; border-radius: 8px; padding: 4px; border: 1px solid #e2e8f0; gap: 4px; }
    .toggle-btn { width: 40px; height: 35px; border: none; background: transparent; border-radius: 6px; font-size: 16px; cursor: pointer; color: #94a3b8; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); font-weight: 800; display: flex; align-items: center; justify-content: center; }
    .toggle-btn:hover { background: #e2e8f0; color: #64748b; }
    .toggle-btn.yes.active { background: #10b981; color: white; box-shadow: 0 4px 10px rgba(16, 185, 129, 0.4); transform: scale(1.05); }
    .toggle-btn.no.active { background: #ef4444; color: white; box-shadow: 0 4px 10px rgba(239, 68, 68, 0.4); transform: scale(1.05); }

    .chart-container { width: 100%; max-width: 320px; margin: 0 auto 20px; }

    .legend { display: flex; gap: 15px; flex-wrap: wrap; }
    .legend-item { display: flex; align-items: center; gap: 6px; font-size: 0.85rem; font-weight: 700; color: #64748b; }
    .dot { width: 12px; height: 12px; border-radius: 50%; }

    /* Chips Multi-Dias */
    .day-pill input[type="checkbox"] { display: none; }
    .day-pill span { display: inline-block; padding: 8px 14px; border-radius: 8px; background: #f8fafc; color: #64748b; font-weight: 800; font-size: 13px; cursor: pointer; border: 1px solid #e2e8f0; transition: all 0.2s ease; user-select: none; }
    .day-pill input[type="checkbox"]:checked + span { background: var(--azul-marinho); color: #fff; border-color: var(--azul-marinho); box-shadow: 0 4px 10px rgba(46,134,193,0.3); transform: translateY(-2px); }

    /* Tabela de eventos */
    .event-table { width: 100%; border-collapse: collapse; }
    .event-table th { background: #f8fafc; padding: 12px; font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; border-bottom: 2px solid #e2e8f0; }
    .event-table td { padding: 12px; border-bottom: 1px solid #f0f4f8; color: #334155; font-size: 0.9rem; }
    .event-table tr:hover { background: #f8fafc; }
    .btn-sm { padding: 6px 12px; border-radius: 6px; border: none; font-size: 0.75rem; font-weight: 700; cursor: pointer; }
    .btn-sm.orange { background: #f97316; color: white; }
    .btn-sm.red { background: #ef4444; color: white; }
    .btn-sm.blue { background: var(--azul-marinho); color: white; }
</style>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 15px;">
    <div class="legend">
        <div class="legend-item"><div class="dot" style="background: #f97316;"></div> Evento Único</div>
        <div class="legend-item"><div class="dot" style="background: #10b981;"></div> Evento Fixo (Cultos)</div>
    </div>
    <div style="display: flex; gap: 12px;">
        <button onclick="openModalForm('evento')" class="btn-primary" style="box-shadow: 0 4px 12px rgba(46,134,193,0.2);"><i class="fas fa-plus"></i> Novo Evento</button>
        <button onclick="openModalForm('agenda')" class="btn-primary" style="background: var(--verde-folha); box-shadow: 0 4px 12px rgba(16,185,129,0.2);"><i class="fas fa-clock"></i> Novo Fixo</button>
        <button onclick="openListaEventos()" class="btn-primary" style="background: #f97316; box-shadow: 0 4px 12px rgba(249,115,22,0.3);"><i class="fas fa-list"></i> Listar Eventos</button>
    </div>
</div>

<div class="calendar-container">
    <div id='calendar'></div>
</div>

<!-- Modal de Gestão (inscrição/chamada/relatório) -->
<div id="modal-gestao" class="modal-overlay">
    <div class="modal-content">
        <button onclick="closeModal('modal-gestao')" style="position:absolute; top:15px; right:15px; border:none; background:rgba(255,255,255,0.2); width:35px; height:35px; border-radius:50%; z-index:100; cursor:pointer; color: white; font-size: 18px; transition: 0.2s;">&times;</button>

        <div style="padding: 25px 20px; background: linear-gradient(135deg, var(--azul-marinho), #1e40af); border-radius: 20px 20px 0 0; color: white; text-align: center;">
            <h3 id="gestao-title" style="margin: 0; font-weight: 900; font-size: 1.5rem;"></h3>
            <p id="gestao-subtitle" style="margin: 6px 0 0; font-size: 0.9rem; opacity: 0.8; font-weight: 600;"></p>
        </div>

        <div class="modal-tabs" style="border-radius: 0;">
            <button class="tab-btn active" onclick="switchTab('tab-inscricao')"><i class="fas fa-list"></i> 1. Inscrição</button>
            <button class="tab-btn" onclick="switchTab('tab-presenca')"><i class="fas fa-user-check"></i> 2. Chamada</button>
            <button class="tab-btn" onclick="switchTab('tab-grafico'); drawChart();"><i class="fas fa-chart-pie"></i> 3. Relatório</button>
        </div>

        <div id="tab-inscricao" class="tab-content">
            <div style="padding: 15px 20px; background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                <p style="font-size: 0.8rem; color: #64748b; margin: 0 0 12px;"><i class="fas fa-info-circle"></i> Marque <b>V (Verde)</b> para inscrever a pessoa. Apenas os inscritos aparecerão na Chamada.</p>
                <input type="text" id="search-membro" placeholder="Buscar pelo nome..." onkeyup="filterList('lista-inscricao', this.value)" style="width:100%; padding:12px; border:1px solid #cbd5e1; border-radius:8px; outline:none; font-weight: 600; color: var(--azul-marinho);">
            </div>
            <div id="lista-inscricao" style="height: 350px; overflow-y:auto; padding-bottom: 10px;"></div>
        </div>

        <div id="tab-presenca" class="tab-content" style="display:none;">
            <div style="padding: 15px 20px; background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                <p style="font-size: 0.8rem; color: #64748b; margin: 0;"><i class="fas fa-info-circle"></i> Hora da chamada! Marque <b>V</b> se compareceu e <b>X</b> se faltou.</p>
            </div>
            <div id="lista-presenca" style="height: 400px; overflow-y:auto; padding-bottom: 10px;"></div>
        </div>

        <div id="tab-grafico" class="tab-content" style="display:none; padding: 40px 20px; text-align: center;">
            <div class="chart-container"><canvas id="presencaChart"></canvas></div>
            <div id="chart-stats" style="display: flex; justify-content: space-around; font-weight: 700; color: #334155; margin-top: 20px; background: #f8fafc; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0;"></div>
        </div>

        <div style="padding: 20px; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; background: #fff; border-radius: 0 0 20px 20px; flex-wrap: wrap; gap: 10px;">
            <div style="display: flex; gap: 8px;">
                <button id="btn-edit-gestao" class="btn-primary" style="background: #e2e8f0; color: #475569; padding: 12px 15px; font-weight: 800;" title="Editar Configurações"><i class="fas fa-pen"></i> Editar</button>
                <button id="btn-del-gestao" class="btn-primary" style="background: #fee2e2; color: #ef4444; padding: 12px 15px; font-weight: 800;" title="Excluir Dia"><i class="fas fa-trash"></i> Apagar Dia</button>
                <button id="btn-del-agenda" class="btn-primary" style="display: none; background: #fca5a5; color: #7f1d1d; padding: 12px 15px; font-weight: 800;" title="Excluir Toda a Regra"><i class="fas fa-calendar-times"></i> Apagar Regra</button>
            </div>
            <button onclick="salvarGestaoLote()" class="btn-primary" style="padding: 12px 30px; font-size: 1rem; box-shadow: 0 4px 15px rgba(46,134,193,0.3); font-weight: 800;"><i class="fas fa-save"></i> Salvar Tudo</button>
        </div>
    </div>
</div>

<!-- Modal de Formulário (criar/editar evento/agenda) -->
<div id="modal-form" class="modal-overlay">
    <div class="modal-content" style="max-width: 450px; padding: 30px;">
        <button onclick="closeModal('modal-form')" style="position:absolute; top:20px; right:20px; border:none; background:#f1f5f9; width: 35px; height: 35px; border-radius: 50%; font-size:20px; color: #64748b; cursor: pointer;">&times;</button>
        <h3 id="form-title" style="margin-bottom:25px; color:var(--azul-marinho); font-weight: 800;"></h3>
        <form method="POST">
            <input type="hidden" name="tipo_acao" id="tipo_acao">
            <input type="hidden" name="id_edicao" id="id_edicao">

            <label style="display:block; font-size:12px; font-weight:800; margin-bottom:8px; color: #64748b; text-transform: uppercase;">Título</label>
            <input type="text" name="titulo" id="titulo" required style="width:100%; padding:12px; border:1px solid #e2e8f0; border-radius:10px; margin-bottom:20px; font-weight: 600; color: var(--azul-marinho);">

            <div id="box-evento">
                <label style="display:block; font-size:12px; font-weight:800; margin-bottom:8px; color: #64748b; text-transform: uppercase;">Data e Hora</label>
                <input type="datetime-local" name="data_evento" id="data_evento" style="width:100%; padding:12px; border:1px solid #e2e8f0; border-radius:10px; margin-bottom:20px;">
                <textarea name="descricao" id="descricao" placeholder="Descrição ou observação rápida..." style="width:100%; padding:12px; border:1px solid #e2e8f0; border-radius:10px; margin-bottom:20px;" rows="2"></textarea>
            </div>

            <div id="box-agenda" style="display:none;">
                <div style="margin-bottom:20px;">
                    <label style="display:block; font-size:12px; font-weight:800; margin-bottom:10px; color: #64748b; text-transform: uppercase;">Dias da Semana</label>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <label class="day-pill"><input type="checkbox" name="dia_semana" value="0" class="cb-dia"><span>Seg</span></label>
                        <label class="day-pill"><input type="checkbox" name="dia_semana" value="1" class="cb-dia"><span>Ter</span></label>
                        <label class="day-pill"><input type="checkbox" name="dia_semana" value="2" class="cb-dia"><span>Qua</span></label>
                        <label class="day-pill"><input type="checkbox" name="dia_semana" value="3" class="cb-dia"><span>Qui</span></label>
                        <label class="day-pill"><input type="checkbox" name="dia_semana" value="4" class="cb-dia"><span>Sex</span></label>
                        <label class="day-pill"><input type="checkbox" name="dia_semana" value="5" class="cb-dia"><span>Sáb</span></label>
                        <label class="day-pill"><input type="checkbox" name="dia_semana" value="6" class="cb-dia"><span>Dom</span></label>
                    </div>
                </div>
                <div style="margin-bottom:20px;">
                    <label style="display:block; font-size:12px; font-weight:800; margin-bottom:8px; color: #64748b; text-transform: uppercase;">Horário do Culto</label>
                    <input type="time" name="horario" id="horario" style="width:100%; max-width: 200px; padding:12px; border:1px solid #e2e8f0; border-radius:10px; font-weight: 600;">
                </div>
            </div>

            <label style="display:block; font-size:12px; font-weight:800; margin-bottom:8px; color: #64748b; text-transform: uppercase;">Congregação / Local</label>
            <select name="congregacao_id" id="congregacao_id" style="width:100%; padding:12px; border:1px solid #e2e8f0; border-radius:10px; margin-bottom:25px; font-weight: 600;">
                <option value="">Geral / Sede</option>
                {% for c in congregacoes %}<option value="{{ c.id }}">{{ c.nome }}</option>{% endfor %}
            </select>

            <button type="submit" class="btn-primary" style="width:100%; padding:15px; border-radius: 10px; font-size: 1rem; font-weight: 800; box-shadow: 0 4px 15px rgba(46,134,193,0.3);">Salvar Configuração</button>
        </form>
    </div>
</div>

<!-- MODAL: Lista de Todos os Eventos (botão laranja) -->
<div id="modal-lista-eventos" class="modal-overlay">
    <div class="modal-content" style="max-width: 800px;">
        <button onclick="closeModal('modal-lista-eventos')" style="position:absolute; top:20px; right:20px; border:none; background:#f1f5f9; width: 35px; height: 35px; border-radius: 50%; font-size:20px; color: #64748b; cursor: pointer;">&times;</button>
        <h3 style="padding: 20px; margin:0; background: linear-gradient(135deg, #f97316, #ea580c); color: white; border-radius: 20px 20px 0 0; font-weight: 800;"><i class="fas fa-calendar-alt"></i> Todos os Eventos</h3>
        <div style="padding: 20px; max-height: 60vh; overflow-y: auto;">
            <table class="event-table">
                <thead>
                    <tr><th>Data</th><th>Título</th><th>Congregação</th><th>Tipo</th><th>Inscrições</th><th>Ações</th></tr>
                </thead>
                <tbody id="lista-eventos-tbody">
                    <tr><td colspan="6" style="text-align:center; padding:40px;">Carregando...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
// --- MOTOR ZERADO ---
// Aguardando a nova lógica estrutural...
</script>
{% endblock %}
